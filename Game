    <script>
        // ========== VARIÁVEIS GLOBAIS ==========
        const canvas = document.getElementById('campoJogo');
        const ctx = canvas.getContext('2d');
        const setaCanvas = document.getElementById('setaChute');
        const setaCtx = setaCanvas.getContext('2d');
        
        let posicaoJogador = null;
        let ladoTime = 'A';
        let jogoIniciado = false;
        let jogadorControlado = null;
        let todosJogadores = [];
        let bola = {};
        let golos = {A:0, B:0};
        let tempoJogo = 0;

        // Configurações do campo
        const CAMPO_LARGURA = 1200;
        const CAMPO_ALTURA = 700;
        const AREA_GRANDE_LARGURA = 180;
        const AREA_GRANDE_ALTURA = 400;

        // Configurações de física
        const VELOCIDADE_MAX = 5;
        const ACELERACAO = 0.4;
        const RAIO_ESFERA = 20;
        const RAIO_BOLA = 12;
        const RAIO_HITBOX = 40;

        // Estados de controle
        let joystickAtivo = false;
        let joystickPos = {x:0, y:0};
        let botaoPressionado = false;
        let tempoSegurando = 0;
        let chuteCarregando = false;
        let trajetoriaChute = {angulo:0, forca:0};

        // Posições iniciais por função
        const POSICOES_INICIAIS = {
            A: {
                GK: {x: 60, y: CAMPO_ALTURA/2},
                DF: {x: 200, y: CAMPO_ALTURA/2},
                PD: {x: 350, y: 100},
                PE: {x: 350, y: CAMPO_ALTURA - 100},
                AT: {x: 500, y: CAMPO_ALTURA/2}
            },
            B: {
                GK: {x: CAMPO_LARGURA - 60, y: CAMPO_ALTURA/2},
                DF: {x: CAMPO_LARGURA - 200, y: CAMPO_ALTURA/2},
                PD: {x: CAMPO_LARGURA - 350, y: 100},
                PE: {x: CAMPO_LARGURA - 350, y: CAMPO_ALTURA - 100},
                AT: {x: CAMPO_LARGURA - 500, y: CAMPO_ALTURA/2}
            }
        };

        // ========== CLASSES DO JOGO ==========
        class Jogador {
            constructor(time, funcao, controlado = false) {
                this.time = time;
                this.funcao = funcao;
                this.controlado = controlado;
                this.cor = time === 'A' ? '#FF4444' : '#4444FF';
                this.x = POSICOES_INICIAIS[time][funcao].x;
                this.y = POSICOES_INICIAIS[time][funcao].y;
                this.vx = 0;
                this.vy = 0;
                this.raio = RAIO_ESFERA;
                this.temBola = false;
                this.paralisado = 0;
                this.direcao = 0;
                this.iaEstado = 'procurar';
                this.alvo = null;
            }

            atualizar() {
                if(this.paralisado > 0) {
                    this.paralisado--;
                    this.vx *= 0.85;
                    this.vy *= 0.85;
                    this.mover();
                    return;
                }

                if(this.controlado) {
                    this.controleHumano();
                } else {
                    this.controleIA();
                }

                this.mover();
                this.verificarColisoes();
            }

            controleHumano() {
                if(!joystickAtivo) {
                    this.vx *= 0.92;
                    this.vy *= 0.92;
                    return;
                }

                // Movimento pelo joystick
                const dx = joystickPos.x;
                const dy = joystickPos.y;
                const distancia = Math.sqrt(dx*dx + dy*dy);
                
                if(distancia > 5) {
                    this.direcao = Math.atan2(dy, dx);
                    const fatorVelocidade = Math.min(distancia / 50, 1);
                    
                    this.vx += Math.cos(this.direcao) * ACELERACAO * fatorVelocidade;
                    this.vy += Math.sin(this.direcao) * ACELERACAO * fatorVelocidade;
                    
                    // Limitar velocidade máxima
                    const velocidadeAtual = Math.sqrt(this.vx*this.vx + this.vy*this.vy);
                    if(velocidadeAtual > VELOCIDADE_MAX) {
                        this.vx = (this.vx / velocidadeAtual) * VELOCIDADE_MAX;
                        this.vy = (this.vy / velocidadeAtual) * VELOCIDADE_MAX;
                    }
                } else {
                    this.vx *= 0.92;
                    this.vy *= 0.92;
                }
            }

            controleIA() {
                // Lógica básica de IA: persegue a bola, marca, passa
                if(this.temBola) {
                    this.iaAtacar();
                } else {
                    this.iaDefender();
                }
            }

            iaAtacar() {
                const golAdversario = this.time === 'A' ? CAMPO_LARGURA : 0;
                const distanciaGol = Math.abs(this.x - golAdversario);
                
                if(distanciaGol > 200) {
                    this.moverPara(golAdversario, this.y);
                } else {
                    const jogadoresProximos = todosJogadores.filter(j => 
                        j.time === this.time && j !== this && 
                        Math.hypot(j.x - this.x, j.y - this.y) < 150
                    );
                    if(jogadoresProximos.length > 0) {
                        this.passarBola(jogadoresProximos[0]);
                    } else {
                        this.chutarBola(golAdversario, CAMPO_ALTURA/2, 12);
                    }
                }
            }

            iaDefender() {
                const distanciaBola = Math.hypot(bola.x - this.x, bola.y - this.y);
                
                if(distanciaBola < 120) {
                    this.moverPara(bola.x, bola.y);
                    if(distanciaBola < 40 && bola.dono && bola.dono.time !== this.time) {
                        this.tentarRoubar(bola.dono);
                    }
                } else {
                    this.posicionarTaticamente();
                }
            }

            moverPara(alvoX, alvoY) {
                const angulo = Math.atan2(alvoY - this.y, alvoX - this.x);
                this.vx += Math.cos(angulo) * ACELERACAO * 0.7;
                this.vy += Math.sin(angulo) * ACELERACAO * 0.7;
                
                const velAtual = Math.sqrt(this.vx*this.vx + this.vy*this.vy);
                if(velAtual > VELOCIDADE_MAX * 0.8) {
                    this.vx = (this.vx / velAtual) * VELOCIDADE_MAX * 0.8;
                    this.vy = (this.vy / velAtual) * VELOCIDADE_MAX * 0.8;
                }
            }

            posicionarTaticamente() {
                const posBase = POSICOES_INICIAIS[this.time][this.funcao];
                this.moverPara(posBase.x, posBase.y);
            }

            mover() {
                this.x += this.vx;
                this.y += this.vy;

                // Limitar ao campo
                this.x = Math.max(this.raio, Math.min(CAMPO_LARGURA - this.raio, this.x));
                this.y = Math.max(this.raio, Math.min(CAMPO_ALTURA - this.raio, this.y));

                // Se tem bola, bola vai junto
                if(this.temBola) {
                    bola.x = this.x + Math.cos(this.direcao + Math.PI) * 15;
                    bola.y = this.y + Math.sin(this.direcao + Math.PI) * 15;
                }
            }

            verificarColisoes() {
                todosJogadores.forEach(outro => {
                    if(outro === this) return;
                    
                    const dist = Math.hypot(outro.x - this.x, outro.y - this.y);
                    if(dist < this.raio + outro.raio) {
                        const angulo = Math.atan2(outro.y - this.y, outro.x - this.x);
                        const sobreposicao = (this.raio + outro.raio) - dist;
                        
                        this.x -= Math.cos(angulo) * sobreposicao / 2;
                        this.y -= Math.sin(angulo) * sobreposicao / 2;
                        outro.x += Math.cos(angulo) * sobreposicao / 2;
                        outro.y += Math.sin(angulo) * sobreposicao / 2;
                    }
                });
            }

            desenhar() {
                // Corpo do jogador
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.raio, 0, Math.PI * 2);
                ctx.fillStyle = this.cor;
                ctx.fill();
                ctx.strokeStyle = '#fff';
                ctx.lineWidth = 2;
                ctx.stroke();

                // Hitbox se tem bola
                if(this.temBola) {
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.raio + 6, 0, Math.PI * 2);
                    ctx.strokeStyle = '#FFD700';
                    ctx.lineWidth = 3;
                    ctx.stroke();
                }
            }

            passarBola(destino) {
                if(!this.temBola || !destino) return;
                this.temBola = false;
                bola.dono = destino;
                destino.temBola = true;
                destino.direcao = Math.atan2(bola.y - destino.y, bola.x - destino.x);
                bola.vx = (destino.x - this.x) * 0.12;
                bola.vy = (destino.y - this.y) * 0.12;
            }

            chutarBola(alvoX, alvoY, forca = 10) {
                if(!this.temBola) return;
                this.temBola = false;
                bola.dono = null;
                const angulo = Math.atan2(alvoY - this.y, alvoX - this.x);
                bola.vx = Math.cos(angulo) * forca;
                bola.vy = Math.sin(angulo) * forca;
            }

            tentarRoubar(oponente) {
                if(!oponente || !oponente.temBola) return;
                const distancia = Math.hypot(oponente.x - this.x, oponente.y - this.y);
                if(distancia < 40) {
                    if(Math.random() < 0.45) {
                        oponente.temBola = false;
                        this.temBola = true;
                        bola.dono = this;
                        bola.vx = 0;
                        bola.vy = 0;
                    }
                }
            }
        }

        function desenharCampo() {
            ctx.fillStyle = '#2E8B57';
            ctx.fillRect(0, 0, CAMPO_LARGURA, CAMPO_ALTURA);

            ctx.strokeStyle = '#fff';
            ctx.lineWidth = 4;
            ctx.strokeRect(0, 0, CAMPO_LARGURA, CAMPO_ALTURA);

            ctx.beginPath();
            ctx.moveTo(CAMPO_LARGURA / 2, 0);
            ctx.lineTo(CAMPO_LARGURA / 2, CAMPO_ALTURA);
            ctx.stroke();

            ctx.beginPath();
            ctx.arc(CAMPO_LARGURA / 2, CAMPO_ALTURA / 2, 90, 0, Math.PI * 2);
            ctx.stroke();

            ctx.strokeRect(0, (CAMPO_ALTURA - AREA_GRANDE_ALTURA) / 2, AREA_GRANDE_LARGURA, AREA_GRANDE_ALTURA);
            ctx.strokeRect(CAMPO_LARGURA - AREA_GRANDE_LARGURA, (CAMPO_ALTURA - AREA_GRANDE_ALTURA) / 2, AREA_GRANDE_LARGURA, AREA_GRANDE_ALTURA);
        }

        function desenharBola() {
            ctx.beginPath();
            ctx.arc(bola.x, bola.y, RAIO_BOLA, 0, Math.PI * 2);
            ctx.fillStyle = '#ffffff';
            ctx.fill();
            ctx.strokeStyle = '#000';
            ctx.lineWidth = 2;
            ctx.stroke();
        }

        function desenharHUD() {
            ctx.fillStyle = 'rgba(0,0,0,0.45)';
            ctx.fillRect(10, 10, 280, 60);
            ctx.fillStyle = '#fff';
            ctx.font = '18px sans-serif';
            ctx.fillText(`Time A ${golos.A} x ${golos.B} Time B`, 20, 34);
            ctx.fillText(`Posição: ${posicaoJogador || 'AT'} • Lado: ${ladoTime}`, 20, 56);
        }

        function atualizarBola() {
            if(bola.dono) return;

            bola.x += bola.vx;
            bola.y += bola.vy;

            bola.vx *= 0.97;
            bola.vy *= 0.97;

            if(Math.abs(bola.vx) < 0.03) bola.vx = 0;
            if(Math.abs(bola.vy) < 0.03) bola.vy = 0;

            if(bola.x < RAIO_BOLA) {
                bola.x = RAIO_BOLA;
                bola.vx *= -0.5;
            }
            if(bola.x > CAMPO_LARGURA - RAIO_BOLA) {
                bola.x = CAMPO_LARGURA - RAIO_BOLA;
                bola.vx *= -0.5;
            }
            if(bola.y < RAIO_BOLA) {
                bola.y = RAIO_BOLA;
                bola.vy *= -0.5;
            }
            if(bola.y > CAMPO_ALTURA - RAIO_BOLA) {
                bola.y = CAMPO_ALTURA - RAIO_BOLA;
                bola.vy *= -0.5;
            }

            todosJogadores.forEach(jogador => {
                if(!bola.dono && !jogador.temBola) {
                    const distancia = Math.hypot(jogador.x - bola.x, jogador.y - bola.y);
                    if(distancia < jogador.raio + RAIO_BOLA + 8) {
                        jogador.temBola = true;
                        bola.dono = jogador;
                        bola.vx = 0;
                        bola.vy = 0;
                    }
                }
            });

            if(bola.x < 5) {
                golos.B += 1;
                resetarPosicoes();
            }
            if(bola.x > CAMPO_LARGURA - 5) {
                golos.A += 1;
                resetarPosicoes();
            }
        }

        function resetarPosicoes() {
            todosJogadores.forEach(jogador => {
                const pos = POSICOES_INICIAIS[jogador.time][jogador.funcao];
                jogador.x = pos.x;
                jogador.y = pos.y;
                jogador.vx = 0;
                jogador.vy = 0;
                jogador.temBola = false;
            });

            bola.dono = null;
            bola.vx = 0;
            bola.vy = 0;
            bola.x = CAMPO_LARGURA / 2;
            bola.y = CAMPO_ALTURA / 2;

            const atacante = todosJogadores.find(j => j.time === ladoTime && j.funcao === 'AT');
            if(atacante) {
                atacante.temBola = true;
                bola.dono = atacante;
            }
        }

        function selecionarPosicao(posicao, botao) {
            posicaoJogador = posicao;
            document.querySelectorAll('.posicao-btn').forEach(btn => btn.classList.remove('ring-4', 'ring-destaque'));
            if(botao) botao.classList.add('ring-4', 'ring-destaque');
        }

        function selecionarLado(lado, botao) {
            ladoTime = lado;
            document.querySelectorAll('.lado-btn').forEach(btn => btn.classList.remove('ring-4', 'ring-destaque'));
            if(botao) botao.classList.add('ring-4', 'ring-destaque');
        }

        function iniciarJogo() {
            if(!posicaoJogador) posicaoJogador = 'AT';

            jogoIniciado = true;
            document.getElementById('menuTela').classList.add('hidden');
            document.getElementById('controlesJogo').classList.remove('hidden');

            todosJogadores = [];
            jogadorControlado = null;

            ['A', 'B'].forEach(time => {
                ['GK', 'DF', 'PD', 'PE', 'AT'].forEach(funcao => {
                    const controlado = time === ladoTime && funcao === posicaoJogador;
                    const jogador = new Jogador(time, funcao, controlado);
                    if(controlado) jogadorControlado = jogador;
                    todosJogadores.push(jogador);
                });
            });

            bola = {
                x: CAMPO_LARGURA / 2,
                y: CAMPO_ALTURA / 2,
                vx: 0,
                vy: 0,
                dono: jogadorControlado
            };

            if(jogadorControlado) {
                jogadorControlado.temBola = true;
            }

            ajustarCanvas();
            configurarControles();
            requestAnimationFrame(loopJogo);
        }

        function ajustarCanvas() {
            canvas.width = CAMPO_LARGURA;
            canvas.height = CAMPO_ALTURA;
            setaCanvas.width = CAMPO_LARGURA;
            setaCanvas.height = CAMPO_ALTURA;
        }

        function configurarControles() {
            const joystickArea = document.getElementById('joystickArea');
            const joystickKnob = document.getElementById('joystickKnob');
            const botaoAcao = document.getElementById('botaoAcao');

            joystickArea.addEventListener('pointerdown', event => {
                joystickAtivo = true;
                joystickArea.setPointerCapture(event.pointerId);
            });

            joystickArea.addEventListener('pointermove', event => {
                if(!joystickAtivo) return;
                const rect = joystickArea.getBoundingClientRect();
                const centroX = rect.left + rect.width / 2;
                const centroY = rect.top + rect.height / 2;
                joystickPos.x = event.clientX - centroX;
                joystickPos.y = event.clientY - centroY;
                const limite = rect.width / 2 - 20;
                const distancia = Math.hypot(joystickPos.x, joystickPos.y);
                const fator = distancia > limite ? limite / distancia : 1;
                joystickKnob.style.transform = `translate(${joystickPos.x * fator}px, ${joystickPos.y * fator}px)`;
            });

            joystickArea.addEventListener('pointerup', event => {
                joystickAtivo = false;
                joystickPos = {x: 0, y: 0};
                joystickKnob.style.transform = 'translate(0px, 0px)';
            });

            botaoAcao.addEventListener('pointerdown', () => {
                botaoPressionado = true;
                if(jogadorControlado && jogadorControlado.temBola) {
                    chuteCarregando = true;
                    tempoSegurando = 0;
                } else if(jogadorControlado) {
                    jogadorControlado.vx += Math.cos(jogadorControlado.direcao) * 2;
                    jogadorControlado.vy += Math.sin(jogadorControlado.direcao) * 2;
                }
            });

            botaoAcao.addEventListener('pointerup', () => {
                botaoPressionado = false;
                if(chuteCarregando && jogadorControlado && jogadorControlado.temBola) {
                    const forca = Math.min(16, 5 + tempoSegurando * 0.2);
                    const alvoX = ladoTime === 'A' ? CAMPO_LARGURA : 0;
                    jogadorControlado.chutarBola(alvoX, CAMPO_ALTURA / 2, forca);
                    chuteCarregando = false;
                }
            });
        }

        function desenharSetaChute() {
            setaCtx.clearRect(0, 0, setaCanvas.width, setaCanvas.height);
            if(!chuteCarregando || !jogadorControlado || !jogadorControlado.temBola) return;
            const centroX = jogadorControlado.x;
            const centroY = jogadorControlado.y;
            const angulo = jogadorControlado.direcao;
            const tamanho = 40 + tempoSegurando * 2;
            setaCtx.strokeStyle = '#FFD700';
            setaCtx.lineWidth = 4;
            setaCtx.beginPath();
            setaCtx.moveTo(centroX, centroY);
            setaCtx.lineTo(centroX + Math.cos(angulo) * tamanho, centroY + Math.sin(angulo) * tamanho);
            setaCtx.stroke();
        }

        function loopJogo() {
            if(!jogoIniciado) return;
            if(chuteCarregando) {
                tempoSegurando += 1;
            }

            todosJogadores.forEach(jogador => jogador.atualizar());
            atualizarBola();
            desenharCampo();
            todosJogadores.forEach(jogador => jogador.desenhar());
            desenharBola();
            desenharHUD();
            desenharSetaChute();
            requestAnimationFrame(loopJogo);
        }

        window.addEventListener('resize', ajustarCanvas);
    </script>
</body>
</html>

