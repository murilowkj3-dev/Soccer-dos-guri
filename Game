                    if(outro === this) return;
                    
                    const dist = Math.hypot(outro.x - this.x, outro.y - this.y);
                    if(dist < this.raio + outro.raio) {
                        const angulo = Math.atan2(outro.y - this.y, outro.x - this.x);
                        const sobreposicao = (this.raio + outro.raio) - dist;
                        
                        this.x -= Math.cos(angulo) * sobreposicao / 2;
                        this.y -= Math.sin(angulo) * sobreposicao / 2;
                        outro.x += Math.cos(angulo) * sobreposicao / 2;
                        outro.y += Math.sin(angulo) * sobreposicao / 2;
                    }
                });
            }

